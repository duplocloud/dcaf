# ============================================================================
# DCAF Configuration
# ============================================================================

# Provider Configuration
# Supported: bedrock, google, anthropic, openai, azure, ollama
DCAF_PROVIDER=bedrock
DCAF_MODEL=anthropic.claude-3-sonnet-20240229-v1:0

# Optional: LLM Framework (default: agno)
# DCAF_FRAMEWORK=agno

# Optional: Model Parameters
# DCAF_TEMPERATURE=0.1
# DCAF_MAX_TOKENS=4096

# Optional: A2A Identity
# DCAF_AGENT_NAME=my-agent
# DCAF_AGENT_DESCRIPTION=My helpful agent

# Optional: Behavior Flags
# DCAF_TOOL_CALL_LIMIT=1
# DCAF_DISABLE_HISTORY=false
# DCAF_DISABLE_TOOL_FILTERING=false

# Local development mode — when true, credentials are loaded from env vars
# rather than from injected runtime credentials (e.g., Pranav's selector)
# DCAF_IS_LOCAL=false

# ============================================================================
# Provider Credentials
# ============================================================================

# AWS Bedrock (when DCAF_PROVIDER=bedrock)
AWS_PROFILE=default
AWS_REGION=us-west-2
# Or use direct credentials:
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_SESSION_TOKEN=AKIAXXXXXXXXXXXXXXXX

# Google Vertex AI (when DCAF_PROVIDER=google)
# Project and location are auto-detected on GCP (GKE Workload Identity / metadata service).
# Override manually for local dev:
# GOOGLE_CLOUD_PROJECT=my-gcp-project
# DCAF_GOOGLE_MODEL_LOCATION=us-central1
# For local dev with a service account key file (Application Default Credentials):
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Anthropic Direct (when DCAF_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI (when DCAF_PROVIDER=openai)
# OPENAI_API_KEY=sk-xxxxx

# Azure OpenAI (when DCAF_PROVIDER=azure)
# AZURE_OPENAI_API_KEY=xxxxx

# Ollama (when DCAF_PROVIDER=ollama)
# No credentials needed, runs locally